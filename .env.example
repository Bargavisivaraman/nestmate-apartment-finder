# Copy to .env and fill in.

# PostgreSQL connection. In production this is a Supabase pooler URL.
# Pooled (transaction) connection — used by the running app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct (session) connection — used for migrations / db push / seed:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional. App falls back to a local generator when empty.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional. Enables the admin "Import live listings" sync from RentCast.
RENTCAST_API_KEY=""
